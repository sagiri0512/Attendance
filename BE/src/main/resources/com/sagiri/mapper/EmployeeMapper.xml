<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sagiri.mapper.EmployeeMapper">
    <select id="getEmployeeByEmpNo" resultType="com.sagiri.entity.Employee">
            select id, emp_no, password, real_name, role from employee where emp_no = #{empNo}
    </select>
</mapper>